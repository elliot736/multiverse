@startuml sequence-diagram
title Multiverse — Request Pipeline

actor Client
participant "Middleware\n(createMultiverseMiddleware)" as mw
participant "TenantResolver" as resolver
participant "TenantRegistry" as registry
participant "TenantContext" as ctx
participant "authMiddleware" as auth
participant "OIDC\n(verifyToken)" as oidc
participant "rateLimitMiddleware" as rl
participant "TenantRateLimiter" as limiter
participant "Handler" as handler
participant "TenantQuery" as query
participant "TenantPool" as pool
database "PostgreSQL" as pg

== Tenant Resolution ==

Client -> mw : HTTP request
mw -> resolver : resolve(req)
note right of resolver : HeaderResolver / SubdomainResolver\nPathResolver / JwtResolver / ChainResolver
resolver --> mw : tenantId

mw -> registry : get(tenantId)
note right of registry : MemoryTenantRegistry\nor PostgresTenantRegistry
registry --> mw : Tenant { id, name, tier, config }

mw -> ctx : TenantContext.run(tenant, callback)
note right of ctx : AsyncLocalStorage propagates\ntenant through async call chain

== Authentication ==

ctx -> auth : authMiddleware(req, res, next)
auth -> oidc : verifyToken(token, config)
oidc -> oidc : fetch JWKS, validate signature
oidc --> auth : decoded claims
auth -> auth : cross-reference tenant claim with resolved tenant
alt invalid token
  auth --> Client : 401 Unauthorized
end
auth --> ctx : TenantUser attached to req

== Rate Limiting ==

ctx -> rl : rateLimitMiddleware(req, res, next)
rl -> limiter : consume(tenantId, tier)
limiter -> limiter : select strategy by tier\n(TokenBucket or SlidingWindow)
alt rate limited
  limiter --> Client : 429 Too Many Requests\n+ RateLimit headers
end
limiter --> rl : RateLimitResult { allowed, remaining }
rl --> ctx : next()

== Handler Execution ==

ctx -> handler : handler(req, res)
handler -> query : query(sql, params)
query -> ctx : TenantContext.current()
ctx --> query : current tenant
query -> pool : getConnection()
pool -> pg : SET search_path TO tenant_X, public
pool --> query : scoped connection
query -> pg : execute SQL
pg --> handler : result

== Background: Outbox Relay ==

note over pg, handler
  Within handler transactions:
  Outbox.publish(client, event) writes to _outbox
  in the same transaction as business data
end note

@enduml
